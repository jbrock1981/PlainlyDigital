---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import AppCard from "@/components/AppCard.astro";
import { APPS } from "@/data/apps";
import { COMPANY, FOUNDER } from "@/data/company";

const description =
  "Plainly Digital LLC builds AI-native consumer software on Google Cloud. Patet, our AI money coach, is live — powered by Claude, backed by Plaid, running on Cloud Run + Firebase.";
---

<BaseLayout title="Plainly Digital" description={description}>
  <Hero
    eyebrow="Plainly Digital"
    title="Patet is live. AI money coaching, powered by Claude."
    subtitle="Plainly Digital LLC builds AI-native consumer software on Google Cloud. Patet, our flagship product, is a live web app that reads your real bank transactions through Plaid and coaches you in plain English — powered by Claude as the reasoning layer. Create an account and start today."
  >
    <div class="hero-cta">
      <a class="btn" href="https://patet.plainlydigital.com" target="_blank" rel="noopener noreferrer">Open Patet &mdash; it's live</a>
      <a class="btn btn--ghost" href="/iq">Try the Financial IQ quiz</a>
      <a class="btn btn--ghost" href="/ai">How the AI works</a>
    </div>
  </Hero>

  <section id="apps" aria-labelledby="apps-heading">
    <div class="container">
      <header class="section-head">
        <p class="tag">The product</p>
        <h2 id="apps-heading">Patet — an AI money coach that reads your real bank data.</h2>
        <p class="lead">
          Patet pairs 121 financial literacy lessons with Glyphe, an AI
          coach powered by Claude Sonnet 4.6 that reads your real Plaid
          transactions and coaches you in plain English. Free to start,
          with Pro ($24.99/yr) and Pro+ ($57.99/yr) tiers.
          Live now at <a href="https://patet.plainlydigital.com" target="_blank" rel="noopener noreferrer">patet.plainlydigital.com</a>.
        </p>
      </header>
      <div class="apps-grid">
        {APPS.filter((app) => app.slug === "patet").map((app) => <AppCard app={app} />)}
      </div>
    </div>
  </section>

  <section id="portfolio" aria-labelledby="portfolio-heading">
    <div class="container">
      <header class="section-head">
        <p class="tag">In development</p>
        <h2 id="portfolio-heading">More AI-native apps on the way.</h2>
        <p class="lead">
          Beyond Patet, Plainly Digital is building additional AI-native
          consumer apps — each engineered around Claude as the reasoning
          layer with the same privacy-first architecture.
        </p>
      </header>
      <div class="apps-grid">
        {APPS.filter((app) => app.slug !== "patet").map((app) => <AppCard app={app} />)}
      </div>
    </div>
  </section>

  <section aria-labelledby="how-heading" class="how">
    <div class="container how__inner">
      <header>
        <p class="tag">The way we build</p>
        <h2 id="how-heading">Not another platform. Not another feed.</h2>
      </header>
      <div class="how__grid">
        <div class="how__card">
          <h3>Encrypted at rest, hardened at the API</h3>
          <p>
            Sensitive fields live in iOS Keychain or Android Keystore. APIs are
            rate-limited, audited, and budget-capped. Account deletion is a
            two-tap flow, not a support ticket.
          </p>
        </div>
        <div class="how__card">
          <h3>AI-first <em>and</em> privacy-first</h3>
          <p>
            The model is the product &mdash; but the product isn't the
            model. We pair Claude with input/output guardrails, Unicode-
            normalized crisis routing, NIST AI RMF alignment, and hard
            daily spend caps. Your conversations and financial data are
            not retained beyond what's needed and are never used to train
            any model.
          </p>
        </div>
        <div class="how__card">
          <h3>Web-first, mobile-ready</h3>
          <p>
            Patet runs in your browser today &mdash; no install required.
            Native iOS and Android apps are in development. No notification
            firehose, no engagement tricks. Use it, close it, move on.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section aria-labelledby="model-heading" class="model">
    <div class="container readable">
      <header class="section-head">
        <p class="tag">The business</p>
        <h2 id="model-heading">A digital-native software studio.</h2>
      </header>
      <p class="lead">
        {COMPANY.legalName} is a {COMPANY.state}-registered consumer-software
        company, founded in {COMPANY.founded}. The business model is
        digital-native: subscription software delivered on the web. Patet is
        live at <a href="https://patet.plainlydigital.com" target="_blank" rel="noopener noreferrer">patet.plainlydigital.com</a> with
        three tiers &mdash; Free ($0), Pro ($24.99/yr), and Pro+ ($57.99/yr).
        Revenue scales with software and users, not headcount: no consulting,
        no services, no per-project billing. AI is the core cost and the core
        value &mdash; every product is built around Claude as the reasoning
        layer and runs on Google Cloud infrastructure (Cloud Run, Firebase
        Hosting, Cloud Build, Cloud DNS).
      </p>
    </div>
  </section>

  <section aria-labelledby="who-heading" class="who">
    <div class="container readable">
      <header class="section-head">
        <p class="tag">Who builds this</p>
        <h2 id="who-heading">Built by a founder, not a committee.</h2>
      </header>
      <p class="lead">
        {COMPANY.shortName} is founded and built by {FOUNDER.name}, a
        cybersecurity professional building AI-native consumer apps to make
        everyday life a little easier — and the world a little better. Every
        product carries that security-first discipline: encrypted at rest,
        hardened at the API layer, AI-governed at the model layer.
        {" "}<a href="/about">More about the founder &rarr;</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-cta {
    display: flex;
    gap: var(--pd-space-3);
    flex-wrap: wrap;
  }
  .hero-note {
    margin-top: var(--pd-space-4);
    margin-bottom: 0;
    color: var(--pd-ink-soft);
    font-size: 0.9375rem;
    max-width: var(--pd-max-readable);
  }
  .model {
    background: var(--pd-surface-alt);
  }
  .model .lead,
  .who .lead {
    color: var(--pd-ink-soft);
    margin-bottom: 0;
  }
  .section-head {
    max-width: var(--pd-max-readable);
    margin-bottom: var(--pd-space-12);
  }
  .apps-grid {
    display: grid;
    gap: var(--pd-space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 720px) {
    .apps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1080px) {
    .apps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .how {
    background: var(--pd-surface-alt);
  }
  .how__grid {
    display: grid;
    gap: var(--pd-space-6);
    grid-template-columns: 1fr;
    margin-top: var(--pd-space-8);
  }
  @media (min-width: 768px) {
    .how__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .how__card {
    padding: var(--pd-space-6);
    border-radius: var(--pd-radius);
    background: var(--pd-surface);
    border: 1px solid var(--pd-line);
  }
  .how__card h3 {
    font-size: 1.0625rem;
    margin-bottom: var(--pd-space-2);
  }
  .how__card p {
    color: var(--pd-ink-soft);
    margin: 0;
    font-size: 0.9375rem;
  }
</style>
