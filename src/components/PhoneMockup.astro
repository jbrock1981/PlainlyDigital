---
interface Props {
  label: string;
  accent?: string;
  bg?: string;
}

const { label, accent = "var(--pd-primary)", bg = "var(--pd-surface-alt)" } = Astro.props;
---

<figure class="phone" aria-label={`Mobile preview: ${label}`}>
  <div
    class="phone__frame"
    style={`--phone-accent:${accent};--phone-bg:${bg};`}
  >
    <div class="phone__notch" aria-hidden="true"></div>
    <div class="phone__screen">
      <slot />
    </div>
    <div class="phone__home" aria-hidden="true"></div>
  </div>
  <figcaption class="phone__caption muted">Preview — {label}</figcaption>
</figure>

<style>
  .phone {
    margin: 0;
    display: grid;
    justify-items: center;
    gap: var(--pd-space-3);
  }
  .phone__frame {
    position: relative;
    width: 100%;
    max-width: 320px;
    aspect-ratio: 9 / 19.5;
    background: #0a0a14;
    border-radius: 36px;
    padding: 12px;
    box-shadow:
      var(--pd-shadow-lg),
      inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }
  .phone__notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 26px;
    background: #0a0a14;
    border-radius: 0 0 14px 14px;
    z-index: 2;
  }
  .phone__screen {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 26px;
    background: var(--phone-bg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .phone__home {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    width: 96px;
    height: 4px;
    background: rgba(255, 255, 255, 0.35);
    border-radius: 2px;
  }
  .phone__caption {
    font-size: 0.8125rem;
  }
</style>
