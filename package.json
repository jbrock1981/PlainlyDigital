{
  "name": "plainlydigital",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Plainly Digital LLC — marketing site, legal docs, and parent docs",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "icons:build": "node scripts/export-icons.mjs",
    "audit": "npm audit --audit-level=high",
    "audit:full": "npm audit --audit-level=moderate",
    "lint:links": "linkinator dist --recurse --silent --skip \"^https?://(plainlydigital\\.com|www\\.|.*anthropic\\.com|.*revenuecat\\.com|.*expo\\.dev)\"",
    "lighthouse": "npx --yes @lhci/cli@0.14.x autorun --config=./lighthouserc.json",
    "format": "prettier --write \"src/**/*.{astro,mdx,ts,tsx,css}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{astro,mdx,ts,tsx,css}\" \"*.{json,md}\""
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.2",
    "astro": "^6.4.4"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@resvg/resvg-js": "^2.6.2",
    "linkinator": "^7.6.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
