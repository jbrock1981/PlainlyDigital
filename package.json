{
  "name": "plainlydigital",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Plainly Digital LLC — marketing site, legal docs, and parent docs",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "icons:build": "node scripts/export-icons.mjs",
    "audit": "npm audit --audit-level=high",
    "audit:full": "npm audit --audit-level=moderate",
    "lint:links": "linkinator dist --recurse --silent --skip \"^https?://(plainlydigital\\.com|www\\.|.*anthropic\\.com|.*revenuecat\\.com|.*expo\\.dev)\"",
    "lighthouse": "npx --yes @lhci/cli@0.14.x autorun --config=./lighthouserc.json"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "astro": "^5.18.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "linkinator": "^7.6.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
